{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OVO",
  "version": "0.0.1",
  "identifier": "com.ovoment.ovo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OVO",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      },
      {
        "label": "pet",
        "title": "OVO Pet",
        "url": "/?window=pet",
        "width": 320,
        "height": 320,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local MLX LLM runtime with desktop owl mascot",
    "longDescription": "OVO runs MLX-format LLMs locally on Apple Silicon with a pixel-art owl mascot that wanders your desktop. HuggingFace-native, Ollama/OpenAI API compatible, optional Claude Code integration.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": null,
      "exceptionDomain": ""
    },
    "externalBin": []
  },
  "plugins": {}
}
