{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for OVO main window. Sidecar subprocess is spawned from Rust (no JS shell permissions needed). SQL permissions are reserved for Phase 3 chat persistence.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive",
    "fs:allow-remove",
    "fs:scope-app-recursive",
    "dialog:default",
    "dialog:allow-open"
  ]
}
